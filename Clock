<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>AU A14 Optimized Clock</title>
    <style>
        :root {
            --neon: #00f2ff;
            --bg: #050505;
            --sec: #ff0055;
            /* Force Hardware Acceleration for iPad 9/10 */
            --gpu: translate3d(0,0,0);
        }

        body {
            background-color: var(--bg);
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", sans-serif;
            overflow: hidden;
            touch-action: none;
        }

        /* The Frame: Stays at 1:1 ratio to prevent distortion during morph */
        .clock-frame {
            position: relative;
            width: 360px;
            height: 360px;
            background: rgba(255, 255, 255, 0.05);
            -webkit-backdrop-filter: blur(20px);
            backdrop-filter: blur(20px);
            border-radius: 50%;
            border: 1px solid rgba(0, 242, 255, 0.2);
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.6s cubic-bezier(0.2, 1, 0.2, 1);
            cursor: pointer;
            transform: var(--gpu);
        }

        /* Analog Elements */
        .analog-layer {
            position: absolute;
            width: 100%;
            height: 100%;
            transition: opacity 0.4s ease, transform 0.6s ease;
            transform: var(--gpu);
        }

        #face-canvas { width: 100%; height: 100%; }

        .hand {
            position: absolute;
            bottom: 50%;
            left: 50%;
            transform-origin: 50% 100%;
            border-radius: 10px;
            will-change: transform;
        }
        .hour { width: 7px; height: 80px; background: #fff; z-index: 3; }
        .min { width: 4px; height: 115px; background: #999; z-index: 2; }
        .sec { width: 2px; height: 140px; background: var(--sec); z-index: 4; box-shadow: 0 0 10px var(--sec); }

        /* Digital Elements */
        .digital-layer {
            position: absolute;
            opacity: 0;
            transform: scale(0.6) var(--gpu);
            transition: opacity 0.4s ease, transform 0.6s ease;
            text-align: center;
            pointer-events: none;
        }

        #d-time { 
            font-size: 4.8rem; 
            font-weight: 800; 
            color: var(--neon); 
            margin: 0;
            font-variant-numeric: tabular-nums;
        }

        /* --- THE MORPH LOGIC --- */

        .is-digital {
            /* We use scale to change shape, but keep it a box */
            border-radius: 35px;
            transform: scaleX(1.25) scaleY(0.5) var(--gpu);
            border-color: var(--neon);
        }

        .is-digital .analog-layer {
            opacity: 0;
            transform: scale(0.4) rotate(-20deg) var(--gpu);
        }

        .is-digital .digital-layer {
            opacity: 1;
            /* Counter-scale the text so it doesn't look squashed */
            transform: scaleX(0.8) scaleY(2) var(--gpu); 
        }
    </style>
</head>
<body onclick="toggleMode()">

    <div id="master-clock" class="clock-frame">
        
        <div class="analog-layer">
            <canvas id="face-canvas" width="720" height="720"></canvas>
            <div id="h-hand" class="hand hour"></div>
            <div id="m-hand" class="hand min"></div>
            <div id="s-hand" class="hand sec"></div>
        </div>

        <div class="digital-layer">
            <h1 id="d-time">12:00:00</h1>
            <p id="d-ampm" style="color:var(--neon); margin:0; letter-spacing:4px; font-size:0.8rem;">SYDNEY</p>
        </div>

    </div>

    <script>
        let isDigital = false;
        const canvas = document.getElementById('face-canvas');
        const ctx = canvas.getContext('2d');

        // Draw static face once for A13/A14 efficiency
        function initFace() {
            ctx.clearRect(0,0,720,720);
            ctx.translate(360, 360);
            for (let i = 0; i < 60; i++) {
                ctx.beginPath();
                ctx.lineWidth = i % 5 === 0 ? 5 : 2;
                ctx.strokeStyle = i % 5 === 0 ? "#00f2ff" : "rgba(0, 242, 255, 0.2)";
                ctx.moveTo(0, -310);
                ctx.lineTo(0, i % 5 === 0 ? -345 : -330);
                ctx.stroke();
                ctx.rotate(Math.PI / 30);
            }
            ctx.font = "900 60px -apple-system";
            ctx.fillStyle = "#00f2ff";
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            for (let i = 1; i <= 12; i++) {
                const a = i * Math.PI / 6;
                ctx.fillText(i.toString(), 255 * Math.sin(a), -255 * Math.cos(a));
            }
        }
        initFace();

        function sync() {
            const now = new Date();
            const fmt = new Intl.DateTimeFormat('en-AU', {
                timeZone: "Australia/Sydney",
                hour: 'numeric', minute: 'numeric', second: 'numeric', hour12: true
            });

            const parts = fmt.formatToParts(now);
            const h = parseInt(parts.find(p => p.type === 'hour').value);
            const m = parseInt(parts.find(p => p.type === 'minute').value);
            const s = parseInt(parts.find(p => p.type === 'second').value);
            const ampm = parts.find(p => p.type === 'dayPeriod').value;
            const ms = now.getMilliseconds();

            // Smooth sweep
            const sDeg = (s * 6) + (ms * 0.006);
            const mDeg = (m * 6) + (s * 0.1);
            const hDeg = (h % 12 * 30) + (m * 0.5);

            document.getElementById('s-hand').style.transform = `translateX(-50%) rotate(${sDeg}deg) var(--gpu)`;
            document.getElementById('m-hand').style.transform = `translateX(-50%) rotate(${mDeg}deg) var(--gpu)`;
            document.getElementById('h-hand').style.transform = `translateX(-50%) rotate(${hDeg}deg) var(--gpu)`;

            if (isDigital) {
                document.getElementById('d-time').innerText = `${h}:${m < 10 ? '0'+m : m}:${s < 10 ? '0'+s : s}`;
                document.getElementById('d-ampm').innerText = ampm.toUpperCase() + " • SYDNEY";
            }
        }

        function toggleMode() {
            isDigital = !isDigital;
            document.getElementById('master-clock').classList.toggle('is-digital');
        }

        setInterval(sync, 16);
        sync();
    </script>
</body>
</html>
